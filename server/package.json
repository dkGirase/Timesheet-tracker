{
  "name": "ids-attendance",
  "version": "1.0.0",
  "description": "Attendance management software for IDS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "rimraf dist && tsc",
    "clean": "rimraf dist",
    "migrate": "prisma migrate dev",
    "migrate:create": "prisma migrate dev --name",
